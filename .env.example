# Base de données PostgreSQL (Neon / Supabase / locale)
DATABASE_URL="postgresql://user:password@host:5432/krontrol"

# NextAuth — générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://krontrol.pickajob.fr"

# Bot Telegram dédié Krontrol (BotFather) — vide = mode simulation
TELEGRAM_BOT_TOKEN=""

# Clé API Pennylane — vide = mode simulation
PENNYLANE_API_KEY=""

# Notifications push PWA — générer avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@pickajob.fr"

# Secret des endpoints cron (Vercel Cron)
CRON_SECRET=""
